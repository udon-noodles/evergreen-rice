{
  "layer": "top",
  "position": "top",
  "height": 40,
  "spacing": 0,
  "margin-top": 8,
  "margin-left": 8,
  "margin-right": 8,

  "modules-left": ["custom/logout"],
  "modules-center": ["clock"],
  "modules-right": [],

  "custom/logout": {
    "format": "⏻",
    "tooltip": false,
    "on-click": "wlogout"
  },

  "clock": {
    "format": " {:%H:%M} ",
    "tooltip": false
  }
}
